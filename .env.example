GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9100
QUEUE_ROOT=.workspace/queue
TASKS_ROOT=.workspace/tasks
WORKER_POLL_MS=1000

# The worker auto-loads this file at startup. For a real local Codex run, the
# main required variable is OPENAI_API_KEY plus a local Codex CLI install.
RUN_TASK_USE_CONTAINER=0
RUN_TASK_CONTAINER_IMAGE=dowhiz/codex-runner:latest
RUN_TASK_CONTAINER_MODE=one_shot
RUN_TASK_CONTAINER_WORKSPACE_ROOT=/srv/dowhiz/tasks
RUN_TASK_CONTAINER_POOL_NAME=dowhiz-codex-pool
RUN_TASK_CONTAINER_ENV_PASSTHROUGH=OPENAI_API_KEY,OPENAI_BASE_URL,CODEX_MODEL,AZURE_OPENAI_API_KEY,AZURE_OPENAI_BASE_URL,AZURE_OPENAI_MODEL
OPENAI_API_KEY=
OPENAI_BASE_URL=
CODEX_MODEL=gpt-5-codex
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_MODEL=
# Optional override. Leave blank to use `codex exec --input-file "$TASK_PROMPT_FILE"`
# automatically when the Codex CLI is available on PATH.
LOCAL_AGENT_COMMAND=
OUTBOUND_DELIVERY_MODE=preview
POSTMARK_API_BASE_URL=https://api.postmarkapp.com
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_TAG=dowhiz-task-result
